POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=seo_crawler
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/seo_crawler
LOG_LEVEL=INFO

SCRAPY_USER_AGENT=seo-crawler/0.1 (+local)
SCRAPY_CONCURRENT_REQUESTS=8
SCRAPY_DOWNLOAD_TIMEOUT=20

CRAWL_DEFAULT_MAX_URLS=500
CRAWL_DEFAULT_MAX_DEPTH=3
CRAWL_DEFAULT_REQUEST_DELAY=0.25

FRONTEND_APP_URL=http://127.0.0.1:5173
GSC_CLIENT_SECRETS_PATH=.local/gsc/credentials.json
GSC_TOKEN_PATH=.local/gsc/token.json
GSC_OAUTH_STATE_PATH=.local/gsc/oauth_state.json
GSC_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/gsc/oauth/callback
GSC_DEFAULT_TOP_QUERIES_LIMIT=20
GSC_METRICS_ROW_LIMIT=25000
