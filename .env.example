WORKTREE_INSTANCE_ID=main
WORKTREE_STATE_DIR=.local/worktree
COMPOSE_PROJECT_NAME=seo-flow-main

POSTGRES_USER=postgres
# After a successful DB connection, local startup stores trusted POSTGRES_USER /
# POSTGRES_PASSWORD / POSTGRES_DB values in .local/postgres/credentials.env so the
# Docker volume keeps using one stable identity. To deliberately adopt new DB
# credentials, update .env and run db-reset, db-refresh-lock, or db-align-password.
POSTGRES_PASSWORD=postgres
POSTGRES_DB=seo_crawler
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Scripts regenerate this from the locked POSTGRES_* values plus the current host/port.
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/seo_crawler
LOG_LEVEL=INFO
API_PORT=8000

SCRAPY_USER_AGENT=seo-crawler/0.1 (+local)
SCRAPY_CONCURRENT_REQUESTS=8
SCRAPY_DOWNLOAD_TIMEOUT=20

CRAWL_DEFAULT_MAX_URLS=500
CRAWL_DEFAULT_MAX_DEPTH=10
CRAWL_DEFAULT_REQUEST_DELAY=0.25

FRONTEND_APP_URL=http://127.0.0.1:5173
GSC_CLIENT_SECRETS_PATH=.local/worktree/gsc/credentials.json
GSC_TOKEN_PATH=.local/worktree/gsc/token.json
GSC_OAUTH_STATE_PATH=.local/worktree/gsc/oauth_state.json
GSC_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/gsc/oauth/callback
GSC_DEFAULT_TOP_QUERIES_LIMIT=20
GSC_METRICS_ROW_LIMIT=25000

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_LLM_ENABLED=true
OPENAI_MODEL_COMPETITOR_EXTRACTION=gpt-5-mini
OPENAI_MODEL_COMPETITOR_MERGE=gpt-5.4-mini
OPENAI_MODEL_COMPETITOR_EXPLANATION=gpt-5-mini
CONTENT_GAP_READ_MODEL_MODE=legacy
OPENAI_TIMEOUT_SECONDS=20
OPENAI_MAX_RETRIES=2
